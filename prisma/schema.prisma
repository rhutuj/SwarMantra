generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Raag {
  id        String     @id @default(uuid())
  name      String
  thaat     String?
  aaroh     String?
  avroh     String?
  pakad     String?
  vadi      String?
  samvadi   String?
  komalSur  String?
  tivraSur  String?
  jati      String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  sargams   Sargam[]
  bandishes Bandish[]
}

model Sargam {
  id           String   @id @default(uuid())
  raag         Raag     @relation(fields: [raagId], references: [id])
  raagId       String
  title        String
  taal         String?
  bpm          Int?
  laya         String?
  asthayi      String?
  antara       String?
  notes        String?
  startingBeat Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  taans        Taan[]
}

model Bandish {
  id           String   @id @default(uuid())
  raag         Raag     @relation(fields: [raagId], references: [id])
  raagId       String
  title        String
  taal         String?
  bpm          Int?
  laya         String?
  composer     String?
  lyrics       String?
  asthayi      String?
  antara       String?
  notes        String?
  startingBeat Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  taans        Taan[]
}

model Taan {
  id            String   @id @default(uuid())
  notation      String?
  startingMatra Int      @default(1)
  textNote      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sargam        Sargam?  @relation(fields: [sargamId], references: [id])
  sargamId      String?
  bandish       Bandish? @relation(fields: [bandishId], references: [id])
  bandishId     String?
}
